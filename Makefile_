Undefined reference to Server::Server()
**************************************

NAME = ft_IRC

SRC_DIR = ./src
OBJ_DIR = ./obj
DIR = ./obj ./obj/Command

SRC = 	main.cpp \
		Server.cpp \
		Client.cpp \
		Channel.cpp \
		Command.cpp \
		Command/join.cpp \
		utils.cpp
		
SRCS = $(addprefix $(SRC_DIR)/, $(SRC))

OBJ = $(SRC:.cpp=.o)
OBJS = $(addprefix $(OBJ_DIR)/, $(OBJ))

CC = c++
CPPFLAGS = -Wall -Wextra -Werror -std=c++98 -I ./include -g 
INCLUDES = -I/usr/include

MKDIR = mkdir -p
RM = rm -rf

all: $(NAME)

$(DIR):
	$(MKDIR) $(DIR)

$(NAME): $(OBJS) | $(DIR)
	@${CC} ${CPPFLAGS} ${OBJS} -o $(NAME)

$(OBJ_DIR)/%.o: $(SRC_DIR)/%.cpp | $(DIR)
	@$(CC) $(CPPFLAGS) -o $@ -cpp $< $(INCLUDES)

clean:
	@$(RM) $(OBJ_DIR)
fclean: clean
	@$(RM) $(NAME)
re: fclean all

.PHONY : all clean fclean re

